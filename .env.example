# ===========================================
# AI Dev Agency - Environment Configuration
# ===========================================

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_dev_agency
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_dev_agency

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=your-256-bit-secret-key-change-in-production

# =============================================================================
# Authentication (Phase 9B)
# =============================================================================
# Optional: Pre-configure admin account (if not set, setup screen shows on first visit)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD_HASH=bcrypt-hash-of-password

# JWT token settings (defaults shown, can be overridden)
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7
# IDLE_TIMEOUT_MINUTES=30

# =============================================================================
# LLM API (Required)
# =============================================================================
OPENROUTER_API_KEY=sk-or-your-openrouter-key
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# =============================================================================
# Code Generation (Required)
# =============================================================================
VERCEL_V0_API_KEY=your-v0-platform-api-key

# =============================================================================
# GitHub (Required for delivery)
# =============================================================================
GITHUB_TOKEN=ghp_your-github-personal-access-token

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# Frontend Configuration
# =============================================================================
VITE_API_URL=http://localhost:8000

# =============================================================================
# Redis (Caching & Task Queue)
# =============================================================================
REDIS_URL=redis://redis:6379

# =============================================================================
# Docker Integration (Phase 4)
# =============================================================================
# Options: "sdk" (uses Python Docker SDK) or "subprocess" (uses docker CLI)
DOCKER_INTEGRATION_MODE=sdk

# =============================================================================
# Security Agent - Semgrep (Phase 4)
# =============================================================================
# Optional: Semgrep API token for pro features
# Get your token at: https://semgrep.dev/settings/tokens
SEMGREP_API_TOKEN=optional-for-pro-features

# =============================================================================
# Auto-fix Configuration (Phase 4)
# =============================================================================
AUTO_FIX_ENABLED=true

# =============================================================================
# Playwright Service (Phase 4 - Accessibility)
# =============================================================================
PLAYWRIGHT_HOST=playwright
PLAYWRIGHT_PORT=3200

# =============================================================================
# Deployment Platforms (Phase 5)
# =============================================================================
# Vercel deployment - Get token at: https://vercel.com/account/tokens
VERCEL_TOKEN=your-vercel-token

# Railway deployment - Get token at: https://railway.app/account/tokens
RAILWAY_TOKEN=your-railway-token

# Expo EAS Build - Get token at: https://expo.dev/accounts/[account]/settings/access-tokens
EXPO_TOKEN=your-expo-token

# =============================================================================
# Monitoring & Analytics (Phase 6 - All Optional)
# =============================================================================
# Sentry error tracking - Get DSN at: https://sentry.io
SENTRY_DSN=your-sentry-dsn

# Plausible Analytics - Get API key at: https://plausible.io/settings
# Privacy-focused, GDPR-compliant analytics
PLAUSIBLE_API_KEY=your-plausible-api-key

# Google Analytics 4 - Get Measurement ID from GA4 dashboard
# Format: G-XXXXXXXXXX
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# UptimeRobot - Get API key at: https://uptimerobot.com/dashboard#mySettings
UPTIMEROBOT_API_KEY=your-uptimerobot-api-key

# Lighthouse CI Server - Get token from your LHCI server
# Optional: Uses temporary public storage if not configured
LIGHTHOUSE_CI_TOKEN=your-lighthouse-ci-token

# =============================================================================
# Notifications (Optional)
# =============================================================================
SLACK_WEBHOOK_URL=your-slack-webhook-url

# =============================================================================
# Phase 10: Integrations
# =============================================================================

# -----------------------------------------------------------------------------
# AGENCY SYSTEM INTEGRATIONS
# These are used by agents DURING project generation
# -----------------------------------------------------------------------------

# Figma MCP Integration
# Extracts design context (colors, typography, layout) from Figma files
# Used by: Research Agent, Design System Agent, Architect Agent
# Get token at: https://www.figma.com/developers/api#access-tokens
FIGMA_ACCESS_TOKEN=figd_your-figma-personal-access-token

# BrowserStack Integration (Optional)
# Runs cross-browser tests on real devices during QA
# Used by: QA Agent (falls back to local Playwright if not configured)
# Get credentials at: https://www.browserstack.com/accounts/settings
# BROWSERSTACK_USERNAME=your-browserstack-username
# BROWSERSTACK_ACCESS_KEY=your-browserstack-access-key

# -----------------------------------------------------------------------------
# GENERATED PROJECT DEFAULTS  
# These are auto-injected into generated SaaS projects when applicable
# -----------------------------------------------------------------------------

# Resend Email Integration
# Auto-integrated for web_complex, python_saas projects with authentication
# Generates React Email templates + send utility
# Get API key at: https://resend.com/api-keys
# RESEND_API_KEY=re_your-resend-api-key

# Cloudflare R2 Storage Integration
# Auto-integrated for projects with file upload features
# Generates upload utility with presigned URLs
# Get credentials at: https://dash.cloudflare.com/ -> R2 -> Manage R2 API Tokens
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=your-bucket-name
# R2_ACCOUNT_ID=your-cloudflare-account-id

# Inngest Background Jobs Integration
# Auto-integrated for python_saas, web_complex projects with async tasks
# Generates background job functions
# Get event key at: https://app.inngest.com/env/production/manage/keys
# INNGEST_EVENT_KEY=your-inngest-event-key

# =============================================================================
# LangSmith Tracing (Phase 12 — Optional)
# =============================================================================
# Full end-to-end observability across all 20 agents.
# Set LANGCHAIN_TRACING_V2=true to enable. Get API key at: https://smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_your-langsmith-api-key
# LANGCHAIN_PROJECT=ai-dev-agency
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
