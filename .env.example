# ===========================================
# AI Dev Agency - Environment Configuration
# ===========================================

# Core
# ----
DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_dev_agency
SECRET_KEY=your-256-bit-secret-key-change-in-production

# LLM API (Required)
# ------------------
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Code Generation (Required)
# --------------------------
VERCEL_V0_API_KEY=your-v0-platform-api-key

# GitHub (Required for delivery)
# ------------------------------
GITHUB_TOKEN=ghp_your-github-personal-access-token

# Deployment Platforms (Optional)
# -------------------------------
VERCEL_TOKEN=your-vercel-token
RAILWAY_TOKEN=your-railway-token

# Monitoring (Optional)
# ---------------------
SENTRY_DSN=your-sentry-dsn

# Notifications (Optional)
# ------------------------
SLACK_WEBHOOK_URL=your-slack-webhook-url
